<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#0f172a">
    <link rel="manifest" href="/manifest.json">
    <link rel="icon" type="image/svg+xml" href="/icons/icon.svg">
    <link rel="icon" type="image/png" sizes="192x192" href="/icons/icon-192x192.png">
    <link rel="apple-touch-icon" href="/icons/icon-192x192.png">
    <title>Login - DrowsyCraft</title>
    <link rel="stylesheet" href="/styles/main.css?v=1.9">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        body { 
            background: #0f172a;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            font-family: 'Inter', sans-serif;
            color: #e1e1e6;
            overflow: hidden;
        }
        
        /* --- SPLASH SCREEN --- */
        #splash-screen {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: #0f172a; z-index: 9999;
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1), visibility 0.8s;
        }
        #splash-screen.hidden { opacity: 0; visibility: hidden; transform: scale(1.05); }
        .splash-logo { 
            font-size: 3.5rem; text-transform: uppercase; letter-spacing: 4px; font-weight: 800; 
            background: linear-gradient(to right, #8b5cf6, #3b82f6);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            margin-bottom: 15px; animation: float 3s ease-in-out infinite;
        }
        .splash-text { color: #94a3b8; font-size: 1.1rem; letter-spacing: 2px; text-transform: uppercase; }
        @keyframes float { 
            0%, 100% { transform: translateY(0); } 
            50% { transform: translateY(-10px); } 
        }
        
        /* --- LOGIN CONTAINER (CLEAN SLATE) --- */
        .login-container {
            background: #1e293b;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.2), 0 10px 10px -5px rgba(0, 0, 0, 0.1);
            width: 100%;
            max-width: 400px;
            border: 1px solid #334155;
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
            transition-delay: 0.3s;
        }
        .login-container.visible { opacity: 1; transform: translateY(0); }
        
        .login-header { text-align: center; margin-bottom: 30px; }
        .login-header h1 { color: #f8fafc; font-size: 28px; margin-bottom: 10px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; }
        .login-header p { color: #94a3b8; font-size: 14px; }
        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; margin-bottom: 8px; color: #cbd5e1; font-weight: 600; font-size: 0.85rem; letter-spacing: 0.5px; text-transform: uppercase; }
        .form-group input {
            width: 100%; padding: 12px 15px; background: #0f172a; color: white;
            border: 1px solid #334155; border-radius: 6px; font-size: 14px;
            transition: border-color 0.3s;
        }
        .form-group input:focus { outline: none; border-color: #6366f1; box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2); }
        .login-btn {
            width: 100%; padding: 12px; background: #6366f1; color: #ffffff; border: none;
            border-radius: 6px; font-size: 16px; font-weight: 700; cursor: pointer;
            transition: all 0.3s ease; margin-top: 10px; text-transform: uppercase; letter-spacing: 1px;
        }
        .login-btn:hover { background: #4f46e5; box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3); transform: translateY(-2px); }
        .error-message {
            color: #f44336; text-align: center; margin-bottom: 20px; padding: 10px;
            background: rgba(244, 67, 54, 0.1); border-radius: 4px; display: none;
        }
        .success-message {
            color: #4caf50; text-align: center; margin-bottom: 20px; padding: 10px;
            background: rgba(76, 175, 80, 0.1); border-radius: 4px; display: none;
        }

        /* --- MOBILE RESPONSIVENESS --- */
        @media (max-width: 600px) {
            .splash-logo { font-size: 2.2rem; letter-spacing: 2px; }
            .splash-text { font-size: 0.85rem; letter-spacing: 1px; }
            .login-container { 
                width: 90%; padding: 30px 20px; 
            }
        }
    </style>
</head>
<body>
    <!-- SPLASH SCREEN -->
    <div id="splash-screen">
        <div class="splash-logo">DrowsyCraft</div>
        <div class="splash-text" id="splash-status">Initializing Portal...</div>
    </div>

    <div class="login-container" id="login-container">
        <div class="login-header">
            <h1>🔐 DrowsyCraft</h1>
            <p>Server Management Dashboard</p>
        </div>
        
        <div id="error-message" class="error-message"></div>
        <div id="success-message" class="success-message"></div>
        
        <form onsubmit="handleLogin(event)">
            <div class="form-group">
                <label for="username">Username</label>
                <input type="text" id="username" placeholder="Enter your Minecraft username" required autofocus>
            </div>
            <button type="submit" class="login-btn">Login</button>
        </form>
    </div>

    <script>
        window.addEventListener('load', () => {
            const token = localStorage.getItem('authToken');
            const splashScreen = document.getElementById('splash-screen');
            const loginContainer = document.getElementById('login-container');
            
            if (token) {
                // If already logged in, smoothly transition straight to dashboard
                document.getElementById('splash-status').textContent = "Authenticating Session...";
                setTimeout(() => {
                    window.location.href = '/dashboard';
                }, 1200);
            } else {
                // Not logged in -> Show splash for 2.5 seconds, then reveal login form
                setTimeout(() => {
                    splashScreen.classList.add('hidden');
                    loginContainer.classList.add('visible');
                }, 2500);
            }
        });

        async function handleLogin(event) {
            event.preventDefault();
            
            const username = document.getElementById('username').value;
            const errorMsg = document.getElementById('error-message');
            const successMsg = document.getElementById('success-message');
            
            if (!username) {
                errorMsg.textContent = 'Username is required';
                errorMsg.style.display = 'block';
                successMsg.style.display = 'none';
                return;
            }
            
            try {
                const response = await fetch('/api/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username })
                });
                
                if (response.ok) {
                    const data = await response.json();
                    successMsg.textContent = 'Login successful! Redirecting...';
                    successMsg.style.display = 'block';
                    errorMsg.style.display = 'none';
                    
                    localStorage.setItem('authToken', data.token);
                    
                    setTimeout(() => {
                        window.location.href = '/dashboard';
                    }, 500);
                } else {
                    const errorText = await response.text();
                    errorMsg.textContent = `Login failed: ${errorText}`;
                    errorMsg.style.display = 'block';
                    successMsg.style.display = 'none';
                    document.getElementById('username').value = '';
                }
            } catch (e) {
                errorMsg.textContent = 'Connection error. Is the server running?';
                errorMsg.style.display = 'block';
                successMsg.style.display = 'none';
            }
        }
        
        // Register Service Worker for PWA
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js')
                    .catch(err => console.log('Service Worker registration failed:', err));
            });
        }
    </script>
</body>
</html>