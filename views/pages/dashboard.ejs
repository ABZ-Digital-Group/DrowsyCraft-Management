            <h3>Create Group</h3>
            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px; margin-bottom: 30px;">
                <input type="text" placeholder="Group name..." id="perm-group-name">
                <input type="text" placeholder="Chat prefix (optional)..." id="perm-group-prefix">
                <input type="color" id="perm-group-color" value="#0e639c">
                <button onclick="createPermissionGroup()" class="btn-success" style="grid-column: 1/-1;">➕ Create Group</button>
            </div>

            <h3>Assign Player to Group</h3>
            <div style="display: flex; gap: 10px; align-items: center; margin-bottom: 30px;">
                <input type="text" id="player-group-assign" placeholder="Player name..." list="players-datalist" style="flex-grow: 1;">
                <select id="group-select" style="flex-grow: 1;"><option value="">Select Group</option></select>
                <button onclick="assignPlayerToGroup()">Assign to Group</button>
            </div>

            <h3>Manage Groups</h3>
            <div id="groups-container"></div>
        </div>

        <!-- LAND CLAIMS -->
        <div id="landc-claims" class="tab">
            <h2>🏗️ Land Claims</h2>
            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px; margin-bottom: 30px;">
                <div class="card">
                    <div class="label">Total Claims</div>
                    <div class="stats" id="claims-total">0</div>
                </div>
                <div class="card">
                    <div class="label">Players with Claims</div>
                    <div class="stats" id="claims-disputed">0</div>
                </div>
                <div class="card">
                    <div class="label">Largest Claim</div>
                    <div class="stats" id="claims-largest">0 blks</div>
                </div>
            </div>
            <h3>Claims List</h3>
            <input type="text" placeholder="Search player..." id="claims-search" onkeyup="filterClaimsTable()">
            <table>
                <thead>
                    <tr>
                        <th>Owner</th>
                        <th>Location</th>
                        <th>Size</th>
                        <th>Members</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="claims-table"></tbody>
            </table>
        </div>

        <!-- ROLEPLAY COMMANDS -->
        <div id="roleplay" class="tab">
            <h2>🎭 Roleplay Commands</h2>
            <h3>Create Command</h3>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                <input type="text" placeholder="Command name..." id="rp-cmd-name">
                <input type="text" placeholder="Command trigger..." id="rp-cmd-trigger">
                <textarea placeholder="Response message..." id="rp-cmd-response" style="grid-column: 1/-1; height: 100px;"></textarea>
                <button onclick="createRoleplayCommand()" class="btn-success" style="grid-column: 1/-1;">➕ Create Command</button>
            </div>
            <h3>Custom Commands</h3>
            <table>
                <thead>
                    <tr>
                        <th>Command</th>
                        <th>Trigger</th>
                        <th>Response</th>
                        <th>Uses</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="roleplay-table"></tbody>
            </table>
        </div>

        <!-- VOTE REWARDS -->
        <div id="voterewards" class="tab">
            <h2>🗳️ Vote Rewards</h2>
            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px; margin-bottom: 30px;">
                <div class="card">
                    <div class="label">Total Votes</div>
                    <div class="stats" id="votes-total">0</div>
                </div>
                <div class="card">
                    <div class="label">This Month</div>
                    <div class="stats" id="votes-month">0</div>
                </div>
                <div class="card">
                    <div class="label">Top Voter</div>
                    <div class="stats" id="votes-top">-</div>
                </div>
            </div>
            <h3>Reward Configuration</h3>
            <div style="background: #252526; border: 1px solid #3e3e42; border-radius: 4px; padding: 15px; margin-bottom: 20px;">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <input type="text" placeholder="Reward command (with {player})..." id="vote-reward-cmd">
                    <input type="number" placeholder="Reward amount" id="vote-reward-amount">
                    <button onclick="setVoteReward()" class="btn-success" style="grid-column: 1/-1;">💾 Save Reward</button>
                </div>
            </div>
            <h3>Vote Leaderboard</h3>
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Player</th>
                        <th>Votes</th>
                        <th>Last Vote</th>
                    </tr>
                </thead>
                <tbody id="votes-table"></tbody>
            </table>
        </div>

        <!-- EVENTS -->
        <div id="events" class="tab">
            <h2>🎄 Event Manager</h2>
            <p style="color: #999; margin-bottom: 20px;">Create seasonal and special events with visual effects on the map!</p>
            
            <h3>Active Events</h3>
            <table>
                <thead>
                    <tr>
                        <th>Event</th>
                        <th>Status</th>
                        <th>Started</th>
                        <th>Players Online</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="active-events-table"></tbody>
            </table>

            <h3>Available Events</h3>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 15px; margin-top: 20px;">
                <div class="card" style="cursor: pointer;" onclick="startEvent('christmas')">
                    <h4 style="color: #4ec9b0;">🎄 Christmas</h4>
                    <p style="font-size: 12px; color: #999;">Falling snow everywhere on the map</p>
                    <button class="btn-success" style="width: 100%; margin-top: 10px;" onclick="event.stopPropagation(); startEvent('christmas')">Enable Event</button>
                </div>
                <div class="card" style="cursor: pointer;">
                    <h4 style="color: #ff9800;">🎃 Halloween</h4>
                    <p style="font-size: 12px; color: #999;">Dark sky, spiders, and creepy effects</p>
                    <button class="btn-success" style="width: 100%; margin-top: 10px;" onclick="event.stopPropagation(); startEvent('halloween')">Enable Event</button>
                    <button class="btn-warning" style="width: 100%; margin-top: 5px;" onclick="event.stopPropagation(); forceHalloweenTime()">Force Midnight</button>
                </div>
                <div class="card" style="cursor: pointer;">
                    <h4 style="color: #9c27b0;">🎆 New Year</h4>
                    <p style="font-size: 12px; color: #999;">Fireworks and confetti particles</p>
                    <button class="btn-success" style="width: 100%; margin-top: 10px;" onclick="event.stopPropagation(); startEvent('newyear')">Enable Event</button>
                </div>
                <div class="card" style="cursor: pointer;">
                    <h4 style="color: #f44336;">❤️ Valentine's Day</h4>
                    <p style="font-size: 12px; color: #999;">Floating hearts and romantic particles</p>
                    <button class="btn-success" style="width: 100%; margin-top: 10px;" onclick="event.stopPropagation(); startEvent('valentine')">Enable Event</button>
                </div>
                <div class="card" style="cursor: pointer;">
                    <h4 style="color: #4ec9b0;">🌸 Spring</h4>
                    <p style="font-size: 12px; color: #999;">Falling cherry blossom petals</p>
                    <button class="btn-success" style="width: 100%; margin-top: 10px;" onclick="event.stopPropagation(); startEvent('spring')">Enable Event</button>
                </div>
                <div class="card" style="cursor: pointer;">
                    <h4 style="color: #ffc107;">☀️ Summer</h4>
                    <p style="font-size: 12px; color: #999;">Bright sun, heat waves, and particles</p>
                    <button class="btn-success" style="width: 100%; margin-top: 10px;" onclick="event.stopPropagation(); startEvent('summer')">Enable Event</button>
                </div>
            </div>
        </div>

        <!-- EVENT LOG -->
        <div id="eventlog" class="tab">
            <h2>📋 Event History</h2>
            <table>
                <thead>
                    <tr>
                        <th>Event</th>
                        <th>Started By</th>
                        <th>Start Time</th>
                        <th>Duration</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody id="event-history-table"></tbody>
            </table>
        </div>

        <!-- DAILY LOGIN REWARDS -->
        <div id="daily-login" class="tab">
            <h2>📅 Daily Login Rewards</h2>
            <div class="card">
                <h3>Settings</h3>
                <div style="margin-bottom:10px;">
                    <label><input type="checkbox" id="daily-login-enabled"> Enable Daily Login Rewards</label>
                </div>
                <div style="margin-bottom:10px;">
                    <label>Base XP Reward:</label><input type="number" id="daily-login-base-xp" value="10" min="1" style="width:80px;">
                </div>
                <div style="margin-bottom:10px;">
                    <label>Streak Bonus (per day):</label><input type="number" id="daily-login-streak-bonus" value="2" min="0" style="width:80px;">
                </div>
                <button class="action-btn" onclick="saveDailyLogin()">💾 Save Settings</button>
                <div id="daily-login-status" style="margin-top:8px;color:#969696;"></div>
            </div>
            <div class="card" style="margin-top:15px;">
                <h3>Player Streaks</h3>
                <table><thead><tr><th>Player</th><th>Streak</th><th>Total Logins</th><th>Last Login</th></tr></thead>
                <tbody id="daily-login-table"></tbody></table>
            </div>
        </div>

        <!-- AUCTION HOUSE -->
        <div id="auction-house" class="tab">
            <h2>🏪 Auction House</h2>
            <div class="card">
                <h3>Create Server Auction</h3>
                <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:10px;">
                    <div><label>Item:</label><input type="text" id="auction-item" placeholder="DIAMOND_SWORD"></div>
                    <div><label>Amount:</label><input type="number" id="auction-amount" value="1" min="1"></div>
                    <div><label>Starting Bid:</label><input type="number" id="auction-start-bid" value="5" min="0"></div>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;">
                    <div><label>Bid Increment:</label><input type="number" id="auction-bid-inc" value="5" min="1"></div>
                    <div><label>Duration (min):</label><input type="number" id="auction-duration" value="60" min="1"></div>
                </div>
                <button class="action-btn" onclick="createAuction()">📦 Create Auction</button>
                <div id="auction-status" style="margin-top:8px;color:#969696;"></div>
            </div>
            <div class="card" style="margin-top:15px;">
                <h3>Active Auctions</h3>
                <table><thead><tr><th>Item</th><th>Seller</th><th>Current Bid</th><th>High Bidder</th><th>Time Left</th><th>Actions</th></tr></thead>
                <tbody id="auction-table"></tbody></table>
            </div>
        </div>

        <!-- NICKNAMES -->
        <div id="nicknames" class="tab">
            <h2>📛 Nicknames</h2>
            <div class="card">
                <h3>Set Player Nickname</h3>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;">
                    <div><label>Player:</label><input type="text" id="nick-player" placeholder="PlayerName"></div>
                    <div><label>Nickname (& color codes):</label><input type="text" id="nick-value" placeholder="&amp;b&amp;lCoolNick"></div>
                </div>
                <button class="action-btn" onclick="setNickname()">Set Nickname</button>
                <button class="action-btn" onclick="clearNickname()" style="background:#e74c3c;">Clear Nickname</button>
                <div id="nick-status" style="margin-top:8px;color:#969696;"></div>
            </div>
            <div class="card" style="margin-top:15px;">
                <h3>Current Nicknames</h3>
                <table><thead><tr><th>Player</th><th>Nickname</th></tr></thead>
                <tbody id="nick-table"></tbody></table>
            </div>
        </div>

        <!-- CHAT TAGS -->
        <div id="chat-tags" class="tab">
            <h2>🏷️ Chat Tags</h2>
            <div class="card">
                <h3>Manage Available Tags</h3>
                <div style="margin-bottom:10px;">
                    <label>New Tag (& color codes):</label><input type="text" id="tag-new" placeholder="&amp;6[&amp;eVIP&amp;6]" style="width:200px;">
                    <button class="action-btn" onclick="addAvailableTag()">Add Tag</button>
                </div>
                <div id="available-tags-list" style="margin-bottom:15px;"></div>
                <h3>Assign Tag to Player</h3>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;">
                    <div><label>Player:</label><input type="text" id="tag-player" placeholder="PlayerName"></div>
                    <div><label>Tag:</label><input type="text" id="tag-value" placeholder="&amp;6[&amp;eVIP&amp;6]"></div>
                </div>
                <button class="action-btn" onclick="setPlayerTag()">Set Tag</button>
                <button class="action-btn" onclick="clearPlayerTag()" style="background:#e74c3c;">Clear Tag</button>
                <div id="tag-status" style="margin-top:8px;color:#969696;"></div>
            </div>
            <div class="card" style="margin-top:15px;">
                <h3>Player Tags</h3>
                <table><thead><tr><th>Player</th><th>Tag</th></tr></thead>
                <tbody id="tag-table"></tbody></table>
            </div>
        </div>

        <!-- SERVER RULES -->
        <div id="server-rules" class="tab">
            <h2>📜 Server Rules</h2>
            <div class="card">
                <h3>Edit Rules</h3>
                <p style="color:#969696;">One rule per line. Players see these with /rules.</p>
                <textarea id="rules-textarea" style="width:100%;height:300px;font-family:monospace;" placeholder="Be respectful&#10;No griefing&#10;No hacking"></textarea>
                <button class="action-btn" style="margin-top:10px;" onclick="saveRules()">💾 Save Rules</button>
                <div id="rules-status" style="margin-top:8px;color:#969696;"></div>
            </div>
        </div>

        <!-- PLAYER WARPS -->
        <div id="player-warps" class="tab">
            <h2>🌀 Player Warps</h2>
            <div class="card">
                <h3>Settings</h3>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;">
                    <div><label>XP Cost to Create:</label><input type="number" id="pwarp-cost" value="5" min="0"></div>
                    <div><label>Max Warps Per Player:</label><input type="number" id="pwarp-max" value="3" min="1"></div>
                </div>
                <button class="action-btn" onclick="savePwarpSettings()">💾 Save Settings</button>
                <div id="pwarp-status" style="margin-top:8px;color:#969696;"></div>
            </div>
            <div class="card" style="margin-top:15px;">
                <h3>All Player Warps</h3>
                <table><thead><tr><th>Name</th><th>Owner</th><th>Location</th><th>Visits</th><th>Actions</th></tr></thead>
                <tbody id="pwarp-table"></tbody></table>
            </div>
        </div>

        <!-- CUSTOM RECIPES -->
        <div id="custom-recipes" class="tab">
            <h2>🧪 Custom Recipes</h2>
            <div class="card">
                <h3>Create Shapeless Recipe</h3>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;">
                    <div><label>Recipe Name:</label><input type="text" id="recipe-name" placeholder="Super Sword"></div>
                    <div><label>Result Item:</label><input type="text" id="recipe-result" placeholder="DIAMOND_SWORD"></div>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;">
                    <div><label>Result Amount:</label><input type="number" id="recipe-amount" value="1" min="1"></div>
                    <div><label>Ingredients (comma-sep):</label><input type="text" id="recipe-ingredients" placeholder="DIAMOND,STICK,GOLD_INGOT"></div>
                </div>
                <button class="action-btn" onclick="createRecipe()">🧪 Create Recipe</button>
                <div id="recipe-status" style="margin-top:8px;color:#969696;"></div>
            </div>
            <div class="card" style="margin-top:15px;">
                <h3>Custom Recipes</h3>
                <table><thead><tr><th>Name</th><th>Result</th><th>Ingredients</th><th>Actions</th></tr></thead>
                <tbody id="recipe-table"></tbody></table>
            </div>
        </div>

        <!-- PVP STATS -->
        <div id="pvp-stats" class="tab">
            <h2>⚔️ PvP Stats & Leaderboard</h2>
            <div class="card">
                <h3>Kill/Death Leaderboard</h3>
                <table><thead><tr><th>#</th><th>Player</th><th>Kills</th><th>Deaths</th><th>K/D</th><th>Current Streak</th><th>Best Streak</th></tr></thead>
                <tbody id="pvp-table"></tbody></table>
            </div>
        </div>

        <!-- ACHIEVEMENTS -->
        <div id="achievements-tab" class="tab">
            <h2>🏆 Achievements & Titles</h2>
            <div class="card">
                <h3>Create Achievement</h3>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;">
                    <div><label>ID:</label><input type="text" id="ach-id" placeholder="kills_100"></div>
                    <div><label>Name:</label><input type="text" id="ach-name" placeholder="Master Slayer"></div>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;">
                    <div><label>Description:</label><input type="text" id="ach-desc" placeholder="Get 100 PvP kills"></div>
                    <div><label>Title Reward (& codes):</label><input type="text" id="ach-title" placeholder="&amp;4[&amp;cSlayer&amp;4]"></div>
                </div>
                <div style="margin-bottom:10px;">
                    <label>XP Reward:</label><input type="number" id="ach-xp" value="50" min="0" style="width:80px;">
                </div>
                <button class="action-btn" onclick="createAchievement()">🏆 Create Achievement</button>
                <div id="ach-status" style="margin-top:8px;color:#969696;"></div>
            </div>
            <div class="card" style="margin-top:15px;">
                <h3>Defined Achievements</h3>
                <table><thead><tr><th>ID</th><th>Name</th><th>Description</th><th>Title</th><th>XP</th><th>Actions</th></tr></thead>
                <tbody id="ach-def-table"></tbody></table>
            </div>
            <div class="card" style="margin-top:15px;">
                <h3>Player Progress</h3>
                <table><thead><tr><th>Player</th><th>Unlocked Achievements</th></tr></thead>
                <tbody id="ach-progress-table"></tbody></table>
            </div>
        </div>

        <!-- DUELS -->
        <div id="duels" class="tab">
            <h2>⚔️ Duels</h2>
            <div class="card">
                <h3>Active Duels</h3>
                <table><thead><tr><th>Player 1</th><th>Player 2</th><th>Wager</th></tr></thead>
                <tbody id="duel-table"></tbody></table>
            </div>
            <div class="card" style="margin-top:15px;">
                <h3>PvP Leaderboard</h3>
                <table><thead><tr><th>Player</th><th>Kills</th><th>Deaths</th></tr></thead>
                <tbody id="duel-stats-table"></tbody></table>
            </div>
        </div>

        <!-- WELCOME SETTINGS -->
        <div id="welcome-settings" class="tab">
            <h2>🎉 First Join Welcome</h2>
            <div class="card">
                <h3>Welcome Settings</h3>
                <div style="margin-bottom:10px;">
                    <label>Welcome Message (& color codes, {player} = name):</label>
                    <input type="text" id="welcome-msg" style="width:100%;" placeholder="&amp;6Welcome to the server, &amp;e{player}&amp;6!">
                </div>
                <div style="margin-bottom:10px;">
                    <label><input type="checkbox" id="welcome-broadcast" checked> Broadcast welcome to server</label>
                </div>
                <div style="margin-bottom:10px;">
                    <label>Starter Items (MATERIAL:amount, one per line):</label>
                    <textarea id="welcome-items" style="width:100%;height:80px;" placeholder="WOODEN_SWORD:1&#10;BREAD:16&#10;LEATHER_BOOTS:1"></textarea>
                </div>
                <button class="action-btn" onclick="saveWelcome()">💾 Save Welcome Settings</button>
                <div id="welcome-status" style="margin-top:8px;color:#969696;"></div>
            </div>
            <div class="card" style="margin-top:15px;">
                <h3>First Join History</h3>
                <table><thead><tr><th>Player</th><th>First Joined</th></tr></thead>
                <tbody id="welcome-table"></tbody></table>
            </div>
        </div>

        <!-- INACTIVE ALERTS -->
        <div id="inactive-alerts" class="tab">
            <h2>⏰ Inactive Player Alerts</h2>
            <div class="card">
                <h3>Settings</h3>
                <div style="margin-bottom:10px;">
                    <label>Inactive Threshold (days):</label>
                    <input type="number" id="inactive-days" value="14" min="1" style="width:80px;">
                    <button class="action-btn" onclick="saveInactiveSettings()">💾 Save</button>
                </div>
                <div id="inactive-status" style="margin-top:8px;color:#969696;"></div>
            </div>
            <div class="card" style="margin-top:15px;">
                <h3>Inactive Players</h3>
                <table><thead><tr><th>Player</th><th>Last Seen</th><th>Days Inactive</th></tr></thead>
                <tbody id="inactive-table"></tbody></table>
            </div>
        </div>

        <!-- SCHEDULED ANNOUNCEMENTS -->
        <div id="sched-announcements" class="tab">
            <h2>📢 Scheduled Announcements</h2>
            <div class="card">
                <h3>Settings</h3>
                <div style="margin-bottom:10px;">
                    <label><input type="checkbox" id="announce-enabled"> Enable Scheduled Announcements</label>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;">
                    <div><label>Interval (minutes):</label><input type="number" id="announce-interval" value="5" min="1"></div>
                    <div><label>Prefix:</label><input type="text" id="announce-prefix" value="&amp;6[&amp;eAnnouncement&amp;6]&amp;r "></div>
                </div>
                <div style="margin-bottom:10px;">
                    <label>Messages (one per line, & color codes):</label>
                    <textarea id="announce-messages" style="width:100%;height:200px;" placeholder="&amp;aRemember to /vote for daily rewards!&#10;&amp;bJoin our Discord: discord.gg/example"></textarea>
                </div>
                <button class="action-btn" onclick="saveAnnouncements()">💾 Save Announcements</button>
                <div id="announce-status" style="margin-top:8px;color:#969696;"></div>
            </div>
        </div>
    </div>
</div>

<script src="/scripts/realm.js?v=17"></script>
</body>
</html>