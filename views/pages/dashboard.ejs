<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Realm Tool - Server Management</title>
    <link rel="stylesheet" href="/styles/main.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
</head>
<body>
<div class="container">
    <div class="sidebar">
        <div class="sidebar-title">DrowsyCraft Management</div>
        <div class="navbar">
            <!-- Overview (Standalone) -->
            <button class="nav-btn active" onclick="switchTab('overview', this)">📊 Overview</button>

            <!-- Player Management -->
            <div class="nav-group" data-permission="webapp.view.players">
                <button class="nav-group-btn expanded" onclick="toggleNavGroup(this)">👥 Player Management</button>
                <div class="nav-group-items">
                    <button class="nav-btn" onclick="switchTab('players', this)" data-permission="webapp.view.players">Players</button>
                    <button class="nav-btn" onclick="switchTab('sessions', this)" data-permission="webapp.view.sessions">Sessions</button>
                    <button class="nav-btn" onclick="switchTab('ips', this)" data-permission="webapp.view.ips">IP Tracking</button>
                    <button class="nav-btn" onclick="switchTab('reputation', this)" data-permission="webapp.view.reputation">Reputation</button>
                    <button class="nav-btn" onclick="switchTab('afk', this)" data-permission="webapp.view.afk">AFK Manager</button>
                </div>
            </div>

            <!-- Moderation & Safety -->
            <div class="nav-group" data-permission="webapp.view.banned">
                <button class="nav-group-btn expanded" onclick="toggleNavGroup(this)">⚖️ Moderation</button>
                <div class="nav-group-items">
                    <button class="nav-btn" onclick="switchTab('moderation', this)" data-permission="webapp.action.ban">Moderation</button>
                    <button class="nav-btn" onclick="switchTab('whitelist', this)" data-permission="webapp.manage.whitelist">Whitelist</button>
                    <button class="nav-btn" onclick="switchTab('mutes', this)" data-permission="webapp.view.mutes">Mutes</button>
                    <button class="nav-btn" onclick="switchTab('punishments', this)" data-permission="webapp.action.punish">Punishments</button>
                    <button class="nav-btn" onclick="switchTab('reports', this)" data-permission="webapp.view.reports">Reports</button>
                </div>
            </div>

            <!-- Communication & Tickets -->
            <div class="nav-group" data-permission="webapp.view.chat">
                <button class="nav-group-btn expanded" onclick="toggleNavGroup(this)">💬 Communication</button>
                <div class="nav-group-items">
                    <button class="nav-btn" onclick="switchTab('chat', this)" data-permission="webapp.view.chat">Chat</button>
                    <button class="nav-btn" onclick="switchTab('notes', this)" data-permission="webapp.view.notes">Notes</button>
                    <button class="nav-btn" onclick="switchTab('tickets', this)" data-permission="webapp.view.tickets">Tickets</button>
                    <button class="nav-btn" onclick="switchTab('templates', this)" data-permission="webapp.view.templates">Templates</button>
                </div>
            </div>

            <!-- Server Management -->
            <div class="nav-group" data-permission="webapp.view.worlds">
                <button class="nav-group-btn expanded" onclick="toggleNavGroup(this)">🌍 Server Mgmt</button>
                <div class="nav-group-items">
                    <button class="nav-btn" onclick="switchTab('worlds', this)" data-permission="webapp.view.worlds">Worlds</button>
                    <button class="nav-btn" onclick="switchTab('plugins', this)" data-permission="webapp.view.plugins">Plugins</button>
                    <button class="nav-btn" onclick="switchTab('gamerules', this)" data-permission="webapp.view.gamerules">Game Rules</button>
                    <button class="nav-btn" onclick="switchTab('blocklog', this)" data-permission="webapp.view.history">Block Log</button>
                    <button class="nav-btn" onclick="switchTab('console', this)" data-permission="webapp.run.command">Console</button>
                    <button class="nav-btn" onclick="switchTab('performance', this)" data-permission="webapp.view.performance">Performance</button>
                    <button class="nav-btn" onclick="switchTab('restart', this)" data-permission="webapp.action.restart">Restart</button>
                </div>
            </div>

            <!-- Events & Seasons -->
            <div class="nav-group" data-permission="webapp.view.events">
                <button class="nav-group-btn expanded" onclick="toggleNavGroup(this)">🎄 Events</button>
                <div class="nav-group-items">
                    <button class="nav-btn" onclick="switchTab('events', this)" data-permission="webapp.view.events">Event Manager</button>
                    <button class="nav-btn" onclick="switchTab('eventlog', this)" data-permission="webapp.view.events">Event History</button>
                </div>
            </div>

            <!-- Analytics & Community -->
            <div class="nav-group" data-permission="webapp.view.analytics">
                <button class="nav-group-btn expanded" onclick="toggleNavGroup(this)">📊 Analytics</button>
                <div class="nav-group-items">
                    <button class="nav-btn" onclick="switchTab('player-analytics', this)" data-permission="webapp.view.analytics">Player Analytics</button>
                    <button class="nav-btn" onclick="switchTab('leaderboards', this)" data-permission="webapp.view.analytics">Leaderboards</button>
                    <button class="nav-btn" onclick="switchTab('economy', this)" data-permission="webapp.view.analytics">Economy</button>
                </div>
            </div>

            <!-- Logging & Audit -->
            <div class="nav-group" data-permission="webapp.view.history">
                <button class="nav-group-btn expanded" onclick="toggleNavGroup(this)">📋 Logging</button>
                <div class="nav-group-items">
                    <button class="nav-btn" onclick="switchTab('history', this)" data-permission="webapp.view.history">History</button>
                    <button class="nav-btn" onclick="switchTab('auditlog', this)" data-permission="webapp.view.audit">Audit Log</button>
                    <button class="nav-btn" onclick="switchTab('warnings', this)" data-permission="webapp.view.warnings">Warnings Log</button>
                    <button class="nav-btn" onclick="switchTab('bulk', this)" data-permission="webapp.action.bulk">Bulk Actions</button>
                    <button class="nav-btn" onclick="switchTab('serverlogs', this)" data-permission="webapp.view.console">Server Logs</button>
                </div>
            </div>

            <!-- Community & Appeals -->
            <div class="nav-group" data-permission="webapp.view.announcements">
                <button class="nav-group-btn expanded" onclick="toggleNavGroup(this)">💬 Community</button>
                <div class="nav-group-items">
                    <button class="nav-btn" onclick="switchTab('appeals', this)" data-permission="webapp.view.applications">Player Appeals</button>
                    <button class="nav-btn" onclick="switchTab('announcements', this)" data-permission="webapp.view.announcements">Announcements</button>
                </div>
            </div>

            <!-- Server Operations -->
            <div class="nav-group" data-permission="webapp.action.backup">
                <button class="nav-group-btn expanded" onclick="toggleNavGroup(this)">⚙️ Operations</button>
                <div class="nav-group-items">
                    <button class="nav-btn" onclick="switchTab('backups', this)" data-permission="webapp.action.backup">Backups</button>
                    <button class="nav-btn" onclick="switchTab('scheduler', this)" data-permission="webapp.manage.announcements">Command Scheduler</button>
                    <button class="nav-btn" onclick="switchTab('maintenance', this)" data-permission="webapp.manage.maintenance">Maintenance Mode</button>
                </div>
            </div>

            <!-- Advanced -->
            <div class="nav-group" data-permission="webapp.manage.groups">
                <button class="nav-group-btn expanded" onclick="toggleNavGroup(this)">🛠️ Advanced</button>
                <div class="nav-group-items">
                    <button class="nav-btn" onclick="switchTab('permissions', this)" data-permission="webapp.manage.groups">Permission Groups</button>
                    <button class="nav-btn" onclick="switchTab('landc-claims', this)" data-permission="webapp.view.claims">Land Claims</button>
                    <button class="nav-btn" onclick="switchTab('roleplay', this)" data-permission="webapp.admin">Roleplay Commands</button>
                    <button class="nav-btn" onclick="switchTab('voterewards', this)" data-permission="webapp.admin">Vote Rewards</button>
                </div>
            </div>

            <!-- Integrations -->
            <div class="nav-group" data-permission="webapp.manage.discord">
                <button class="nav-group-btn expanded" onclick="toggleNavGroup(this)">🔗 Integrations</button>
                <div class="nav-group-items">
                    <button class="nav-btn" onclick="switchTab('discord', this)" data-permission="webapp.manage.discord">Discord</button>
                </div>
            </div>

            <!-- Kits -->
            <button class="nav-btn" onclick="switchTab('kits', this)" data-permission="webapp.view.kits">🎁 Kits</button>

            <!-- Ranks -->
            <button class="nav-btn" onclick="switchTab('ranks', this)" data-permission="webapp.manage.groups">⭐ Ranks</button>

            <!-- High Impact Features -->
            <div class="nav-group" data-permission="webapp.view.crates">
                <button class="nav-group-btn expanded" onclick="toggleNavGroup(this)">🎮 Game Features</button>
                <div class="nav-group-items">
                    <button class="nav-btn" onclick="switchTab('crates', this)" data-permission="webapp.view.crates">Crates</button>
                    <button class="nav-btn" onclick="switchTab('bounties', this)" data-permission="webapp.view.bounties">Bounties</button>
                    <button class="nav-btn" onclick="switchTab('shops', this)" data-permission="webapp.view.shops">Player Shops</button>
                    <button class="nav-btn" onclick="switchTab('quests', this)" data-permission="webapp.view.quests">Quests</button>
                    <button class="nav-btn" onclick="switchTab('enchantments', this)" data-permission="webapp.view.enchantments">Custom Enchants</button>
                </div>
            </div>

            <!-- Admin Features -->
            <div class="nav-group">
                <button class="nav-group-btn expanded" onclick="toggleNavGroup(this)">🛡️ Admin Tools</button>
                <div class="nav-group-items">
                    <button class="nav-btn" onclick="switchTab('applications', this)">Staff Apps</button>
                    <button class="nav-btn" onclick="switchTab('polls', this)">Polls</button>
                    <button class="nav-btn" onclick="switchTab('automod', this)">Auto-Mod</button>
                    <button class="nav-btn" onclick="switchTab('playtime-rewards', this)">Playtime Rewards</button>
                    <button class="nav-btn" onclick="switchTab('motd', this)">MOTD Editor</button>
                </div>
            </div>

            <!-- New Features -->
            <div class="nav-group">
                <button class="nav-group-btn expanded" onclick="toggleNavGroup(this)">✨ New Features</button>
                <div class="nav-group-items">
                    <button class="nav-btn" onclick="switchTab('daily-login', this)">Daily Login</button>
                    <button class="nav-btn" onclick="switchTab('auction-house', this)">Auction House</button>
                    <button class="nav-btn" onclick="switchTab('nicknames', this)">Nicknames</button>
                    <button class="nav-btn" onclick="switchTab('chat-tags', this)">Chat Tags</button>
                    <button class="nav-btn" onclick="switchTab('server-rules', this)">Server Rules</button>
                    <button class="nav-btn" onclick="switchTab('player-warps', this)">Player Warps</button>
                    <button class="nav-btn" onclick="switchTab('custom-recipes', this)">Custom Recipes</button>
                    <button class="nav-btn" onclick="switchTab('pvp-stats', this)">PvP Stats</button>
                    <button class="nav-btn" onclick="switchTab('achievements-tab', this)">Achievements</button>
                    <button class="nav-btn" onclick="switchTab('duels', this)">Duels</button>
                    <button class="nav-btn" onclick="switchTab('welcome-settings', this)">Welcome Settings</button>
                    <button class="nav-btn" onclick="switchTab('inactive-alerts', this)">Inactive Alerts</button>
                    <button class="nav-btn" onclick="switchTab('sched-announcements', this)">Announcements</button>
                </div>
            </div>

            <button class="nav-btn nav-btn-logout" id="logout-btn" onclick="logout()">🚪 Logout</button>
        </div>
    </div>

    <div class="content">
        <!-- OVERVIEW -->
        <div id="overview" class="tab active">
            <h2>📊 Server Overview</h2>
            <div class="grid">
                <div class="card">
                    <div class="label">Online Players</div>
                    <div class="stats" id="stat-players">0</div>
                </div>
                <div class="card">
                    <div class="label">Punished Players</div>
                    <div class="stats" id="stat-punished">0</div>
                </div>
                <div class="card">
                    <div class="label">Open Tickets</div>
                    <div class="stats" id="stat-tickets">0</div>
                </div>
                <div class="card">
                    <div class="label">Muted Players</div>
                    <div class="stats" id="stat-muted">0</div>
                </div>
            </div>

            <h3 style="color: #4ec9b0; margin-top: 30px;"> Broadcast</h3>
            <input type="text" id="broadcast-msg" placeholder="Broadcast message..." class="full-width">
            <button onclick="broadcast()" class="full-width">Send Broadcast</button>
        </div>

        <!-- PLAYERS -->
        <div id="players" class="tab">
            <h2>👥 Online Players</h2>
            <input type="text" id="player-search" placeholder="Search players..." class="full-width" oninput="filterPlayers()">
            <table>
                <tr><th>Name</th><th>Health</th><th>Location</th><th>Warnings</th><th>Playtime</th><th>Status</th><th>Actions</th></tr>
                <tbody id="players-list"></tbody>
            </table>
        </div>

        <!-- TICKETS -->
        <div id="tickets" class="tab">
            <h2>🎫 Tickets</h2>
            <div style="margin-bottom: 15px; display: flex; gap: 10px; flex-wrap: wrap;">
                <select id="ticket-status-filter" style="padding: 6px 10px;">
                    <option value="">All Status</option>
                    <option value="open">Open</option>
                    <option value="in_progress">In Progress</option>
                    <option value="resolved">Resolved</option>
                    <option value="closed">Closed</option>
                </select>
                <select id="ticket-priority-filter" style="padding: 6px 10px;">
                    <option value="">All Priority</option>
                    <option value="low">Low</option>
                    <option value="medium">Medium</option>
                    <option value="high">High</option>
                    <option value="critical">Critical</option>
                </select>
                <button onclick="loadTickets()" style="padding: 6px 12px; background: #2196F3;">Apply Filters</button>
            </div>
            <table>
                <tr><th>ID</th><th>Player</th><th>Priority</th><th>Category</th><th>Status</th><th>Assignee</th><th>Message</th><th>Created</th><th>Action</th></tr>
                <tbody id="tickets-list"></tbody>
            </table>
        </div>

        <!-- TICKET DETAIL MODAL -->
        <div id="ticket-modal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); z-index: 1000; overflow-y: auto;">
            <div style="background: #222; margin: 40px auto; padding: 20px; width: 90%; max-width: 700px; border-radius: 8px; color: #ccc;">
                <h2 id="modal-ticket-id">Ticket #0</h2>
                <div style="margin-bottom: 15px;">
                    <p><strong>Player:</strong> <span id="modal-player">N/A</span></p>
                    <p><strong>Status:</strong> 
                        <select id="modal-status" style="padding: 4px; margin-left: 10px;">
                            <option value="open">Open</option>
                            <option value="in_progress">In Progress</option>
                            <option value="resolved">Resolved</option>
                            <option value="closed">Closed</option>
                        </select>
                    </p>
                    <p><strong>Priority:</strong>
                        <select id="modal-priority" style="padding: 4px; margin-left: 10px;">
                            <option value="low">Low</option>
                            <option value="medium">Medium</option>
                            <option value="high">High</option>
                            <option value="critical">Critical</option>
                        </select>
                    </p>
                    <p><strong>Category:</strong>
                        <select id="modal-category" style="padding: 4px; margin-left: 10px;">
                            <option value="bug">Bug</option>
                            <option value="griefing">Griefing</option>
                            <option value="chat">Chat Abuse</option>
                            <option value="item_loss">Item Loss</option>
                            <option value="pvp">PvP Complaint</option>
                            <option value="other">Other</option>
                        </select>
                    </p>
                    <p><strong>Assignee:</strong> <input type="text" id="modal-assignee" style="padding: 4px; margin-left: 10px; width: 200px;"></p>
                    <p id="modal-location-row" style="display: none;"><strong>Location:</strong> <span id="modal-location">N/A</span></p>
                </div>
                <div style="background: #1a1a1a; padding: 10px; border-radius: 4px; margin-bottom: 15px;">
                    <p><strong>Message:</strong></p>
                    <p id="modal-message" style="margin: 5px 0;">N/A</p>
                </div>
                <div style="background: #1a1a1a; padding: 10px; border-radius: 4px; margin-bottom: 15px;">
                    <p><strong>Responses:</strong></p>
                    <div id="modal-responses" style="max-height: 200px; overflow-y: auto;"></div>
                </div>
                <div style="margin-bottom: 15px;">
                    <p><strong>Add Response:</strong></p>
                    <input type="text" id="modal-admin-name" placeholder="Your name" style="width: 200px; padding: 8px; margin-bottom: 8px; background: #1a1a1a; border: 1px solid #444; color: #ccc;">
                    <input type="text" id="modal-response-text" placeholder="Your response..." style="width: 100%; padding: 8px; margin-bottom: 8px; background: #1a1a1a; border: 1px solid #444; color: #ccc;">
                    <button onclick="addTicketResponse()" style="padding: 6px 12px; background: #4CAF50;">Add Response</button>
                </div>
                <div style="margin-bottom: 15px;">
                    <p><strong>Resolution Reason:</strong></p>
                    <select id="modal-resolution-reason" style="padding: 6px 10px; width: 200px;">
                        <option value="">Not Resolved</option>
                        <option value="fixed">Fixed</option>
                        <option value="false_report">False Report</option>
                        <option value="duplicate">Duplicate</option>
                        <option value="spam">Spam</option>
                        <option value="other">Other</option>
                    </select>
                    <button onclick="resolveTicket()" style="padding: 6px 12px; margin-left: 10px; background: #F44336;">Resolve & Close</button>
                </div>
                <div>
                    <button onclick="updateTicketFields()" style="padding: 6px 12px; background: #2196F3;">Save Changes</button>
                    <button onclick="document.getElementById('ticket-modal').style.display = 'none';" style="padding: 6px 12px; background: #666; margin-left: 10px;">Close</button>
                </div>
            </div>
        </div>

        <!-- NOTES -->
        <div id="notes" class="tab">
            <h2>📝 Player Notes</h2>
            
            <!-- Add Note Section -->
            <div style="background: #252526; padding: 15px; border-radius: 6px; margin-bottom: 20px; border-left: 3px solid #4ec9b0;">
                <h3 style="color: #4ec9b0; margin-bottom: 10px;">Add New Note</h3>
                <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                    <input type="text" id="note-player" placeholder="Player name..." list="players-datalist" style="flex: 1; min-width: 150px;">
                    <select id="note-category" style="width: 140px; background: #2d2d30; color: #e0e0e0; border: 1px solid #3e3e42; border-radius: 4px; padding: 8px;">
                        <option value="info">ℹ️ Info</option>
                        <option value="warning">⚠️ Warning</option>
                        <option value="important">❗ Important</option>
                        <option value="positive">✅ Positive</option>
                    </select>
                </div>
                <textarea id="note-text" placeholder="Write your note here..." style="width: 100%; height: 80px; margin-top: 10px; resize: vertical;"></textarea>
                <button onclick="addNote()" class="full-width btn-success" style="margin-top: 8px;">Add Note</button>
            </div>
            
            <!-- Search / Filter -->
            <div style="display: flex; gap: 10px; margin-bottom: 15px; align-items: center;">
                <input type="text" id="note-search-player" placeholder="🔍 Search player notes..." list="players-datalist" style="flex: 1;" oninput="searchNotes()">
                <button onclick="loadAllNotes()" style="white-space: nowrap;">Show All Players</button>
            </div>
            
            <!-- Notes Display -->
            <div id="notes-summary" style="display: none;"></div>
            <div id="notes-display"></div>
        </div>

        <!-- NOTE DETAIL MODAL -->
        <div id="note-modal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); z-index: 1000; overflow-y: auto;">
            <div style="background: #222; margin: 40px auto; padding: 20px; width: 90%; max-width: 700px; border-radius: 8px; color: #ccc;">
                <h2>📝 Note for <span id="modal-note-player">Player</span></h2>
                <div style="background: #1a1a1a; padding: 15px; border-radius: 4px; margin-bottom: 15px;">
                    <p><strong>Note Content:</strong></p>
                    <textarea id="modal-note-text" style="width: 100%; height: 120px; padding: 8px; background: #2a2a2a; border: 1px solid #444; color: #ccc; border-radius: 4px; font-family: monospace;"></textarea>
                </div>
                <div style="display: flex; gap: 10px;">
                    <button onclick="saveNoteEdit()" style="padding: 8px 16px; background: #4CAF50;">Save Changes</button>
                    <button onclick="deleteNoteFromModal()" style="padding: 8px 16px; background: #F44336;">Delete Note</button>
                    <button onclick="document.getElementById('note-modal').style.display = 'none';" style="padding: 8px 16px; background: #666; margin-left: auto;">Close</button>
                </div>
            </div>
        </div>

        <!-- HISTORY -->
        <div id="history" class="tab">
            <h2>📜 Action History</h2>
            <table>
                <tr><th>Time</th><th>Admin</th><th>Action</th><th>Target</th></tr>
                <tbody id="history-list"></tbody>
            </table>
        </div>

        <!-- CHAT -->
        <div id="chat" class="tab">
            <h2>💬 Chat Monitor</h2>
            <div id="chat-display" style="background: #2d2d30; padding: 15px; border-radius: 4px; height: 400px; overflow-y: auto; margin-bottom: 20px;"></div>
            <button onclick="refreshChat()" class="full-width">Refresh Chat</button>
        </div>

        <datalist id="players-datalist"></datalist>

        <!-- MODERATION -->
        <div id="moderation" class="tab">
            <h2>⚖️ Moderation</h2>
            <div class="grid">
                <div class="card" style="border-left: 4px solid #d32f2f;">
                    <h3 style="color: #f44336; margin-bottom: 15px;">🚫 Ban Player</h3>
                    <input type="text" id="mod-ban-player" placeholder="Player name..." list="players-datalist" style="width: 100%;">
                    <textarea id="mod-ban-reason" placeholder="Ban reason..." rows="4" style="width: 100%; margin-top: 10px;"></textarea>
                    <button onclick="banPlayer()" class="full-width btn-danger" style="margin-top: 10px; font-weight: bold;">BAN PLAYER</button>
                </div>
                <div class="card" style="border-left: 4px solid #ff9800;">
                    <h3 style="color: #ffb74d; margin-bottom: 15px;">⚠️ Warn Player</h3>
                    <input type="text" id="mod-warn-player" placeholder="Player name..." list="players-datalist" style="width: 100%;">
                    <textarea id="mod-warn-reason" placeholder="Warning reason..." rows="4" style="width: 100%; margin-top: 10px;"></textarea>
                    <button onclick="warnPlayer()" class="full-width" style="margin-top: 10px; background: #ff9800; font-weight: bold;">WARN PLAYER</button>
                </div>
                <div class="card" style="border-left: 4px solid #ff6b6b;">
                    <h3 style="color: #ff7979; margin-bottom: 15px;">⏰ Punish 1 Hour</h3>
                    <input type="text" id="mod-punish1h-player" placeholder="Player name..." list="players-datalist" style="width: 100%;">
                    <input type="text" id="mod-punish1h-reason" placeholder="Reason..." style="width: 100%; margin-top: 5px;">
                    <p style="color: #969696; font-size: 12px; margin: 10px 0; font-style: italic;">Lock player in place for 1 hour</p>
                    <button onclick="punishPlayer(60, 'mod-punish1h-player', 'mod-punish1h-reason')" class="full-width" style="margin-top: 5px; background: #d32f2f; font-weight: bold;">PUNISH 1H</button>
                </div>
                <div class="card" style="border-left: 4px solid #e91e63;">
                    <h3 style="color: #f06292; margin-bottom: 15px;">⏰ Punish 3 Hours</h3>
                    <input type="text" id="mod-punish3h-player" placeholder="Player name..." list="players-datalist" style="width: 100%;">
                    <input type="text" id="mod-punish3h-reason" placeholder="Reason..." style="width: 100%; margin-top: 5px;">
                    <p style="color: #969696; font-size: 12px; margin: 10px 0; font-style: italic;">Lock player in place for 3 hours</p>
                    <button onclick="punishPlayer(180, 'mod-punish3h-player', 'mod-punish3h-reason')" class="full-width" style="margin-top: 5px; background: #c2185b; font-weight: bold;">PUNISH 3H</button>
                </div>
            </div>
